{
  "name": "karafun-bridge",
  "version": "1.6.0",
  "description": "Bridges The Regular App song queue to Karafun karaoke software",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --mac",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "make": "electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "better-sqlite3": "^12.9.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "author": {
    "name": "The Regular App",
    "email": "hello@theregularapp.com"
  },
  "build": {
    "appId": "com.theregularapp.karafun-bridge",
    "productName": "Regular App Karafun Bridge",
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "karafun-bridge-${version}-setup.exe"
    },
    "portable": {
      "artifactName": "karafun-bridge-${version}-portable.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.music",
      "artifactName": "karafun-bridge-mac.dmg",
      "identity": null
    },
    "dmg": {
      "title": "Regular App Karafun Bridge"
    },
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
